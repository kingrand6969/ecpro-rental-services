# PostgreSQL connection string (Neon or any Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret used to sign session cookies (generate a long random string)
SESSION_SECRET=change-me

# Port the server listens on (defaults to 5000)
PORT=5000

# Cloudflare R2 object storage (payment screenshots, car photos)
# Create a bucket + an R2 API token with Object Read & Write on that bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
